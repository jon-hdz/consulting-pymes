# Application environment variables example
NEXT_PUBLIC_API_URL=http://localhost:3000

# Google Cloud Service Account
# Obtener desde Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_key_json

# Google Sheets y Drive
# ID del Google Sheet donde guardar respuestas
GOOGLE_SHEETS_ID=your_google_sheet_id

# ID de la carpeta padre en Google Drive donde crear carpetas de clientes
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
